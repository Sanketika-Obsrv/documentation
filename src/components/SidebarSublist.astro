---
import { Icon, Badge } from '@astrojs/starlight/components';

interface SidebarLink {
  type: 'link';
  label: string;
  href: string;
  isCurrent: boolean;
  badge: { text: string; variant: string; class?: string } | undefined;
  attrs: Record<string, string | number | boolean | undefined>;
}

interface SidebarGroup {
  type: 'group';
  label: string;
  entries: SidebarEntry[];
  collapsed: boolean;
  badge: { text: string; variant: string; class?: string } | undefined;
}

type SidebarEntry = SidebarLink | SidebarGroup;

interface Props {
  sublist: SidebarEntry[];
  nested?: boolean;
}

const { sublist, nested } = Astro.props;

// Inline SVG path strings (24×24 viewBox, stroke-based)
const SECTION_ICONS: Record<string, string> = {
  'Welcome to Obsrv': `<path d="M2 12s3.64-8 10-8 10 8 10 8-3.64 8-10 8-10-8-10-8z"/><circle cx="12" cy="12" r="3"/>`,
  'Core Concepts': `<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>`,
  'Explore': `<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>`,
  'Guides': `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
  'Community': `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  'Releases': `<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>`,
  'Previous Versions': `<polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/>`,
  'How-Tos': `<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
};

function hasCurrentEntry(entries: SidebarEntry[]): boolean {
  return entries.some((e) =>
    e.type === 'link' ? e.isCurrent : hasCurrentEntry(e.entries)
  );
}

// If a group's first child is a link with the same label, hoist it as the
// group header link and exclude it from the nested list.
function getIndexLink(entry: SidebarGroup): SidebarLink | null {
  const first = entry.entries[0];
  if (first?.type === 'link' && first.label === entry.label) {
    return first;
  }
  return null;
}

const restoreSymbol = Symbol.for('starlight-sidebar-group-index');
const _locals = Astro.locals as Record<symbol, number>;
const entryRestoreIndices = sublist.map((entry) => {
  if (entry.type !== 'group') return -1;
  const idx = (_locals[restoreSymbol] as number) || 0;
  _locals[restoreSymbol] = idx + 1;
  return idx;
});
---

<ul class:list={{ 'top-level': !nested }}>
  {
    sublist.map((entry, i) => {
      const indexLink = entry.type === 'group' ? getIndexLink(entry) : null;
      const subEntries = entry.type === 'group'
        ? (indexLink ? entry.entries.slice(1) : entry.entries)
        : [];
      return (
        <li>
          {entry.type === 'link' ? (
            <a
              href={entry.href}
              aria-current={entry.isCurrent && 'page'}
              class:list={[{ large: !nested }, entry.attrs.class]}
              {...entry.attrs}
            >
              {!nested && SECTION_ICONS[entry.label] && (
                <svg
                  class="sidebar-group-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  width="17"
                  height="17"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={SECTION_ICONS[entry.label]}
                />
              )}
              <span>{entry.label}</span>
              {entry.badge && (
                <Badge
                  variant={entry.badge.variant as any}
                  class={entry.badge.class}
                  text={entry.badge.text}
                />
              )}
            </a>
          ) : (
            <details open={hasCurrentEntry(entry.entries) || !entry.collapsed}>
              <sl-sidebar-restore data-index={entryRestoreIndices[i]}></sl-sidebar-restore>
              <summary>
                <div class="group-label">
                  {!nested && SECTION_ICONS[entry.label] && (
                    <svg
                      class="sidebar-group-icon"
                      xmlns="http://www.w3.org/2000/svg"
                      width="17"
                      height="17"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      set:html={SECTION_ICONS[entry.label]}
                    />
                  )}
                  {indexLink ? (
                    <a
                      href={indexLink.href}
                      class="large group-nav-link"
                      aria-current={indexLink.isCurrent ? 'page' : undefined}
                    >
                      {entry.label}
                    </a>
                  ) : (
                    <span class="large">{entry.label}</span>
                  )}
                  {entry.badge && (
                    <Badge
                      variant={entry.badge.variant as any}
                      class={entry.badge.class}
                      text={entry.badge.text}
                    />
                  )}
                </div>
                <Icon name="right-caret" class="caret" size="1.25rem" />
              </summary>
              <Astro.self sublist={subEntries} nested />
            </details>
          )}
        </li>
      );
    })
  }
</ul>

<script>
  // Clicking the group header link should navigate without toggling the <details>
  document.querySelectorAll<HTMLAnchorElement>('summary a.group-nav-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  });
</script>

<style>
  ul {
    --sl-sidebar-item-padding-inline: 0.5rem;
    list-style: none;
    padding: 0;
  }

  li {
    overflow-wrap: anywhere;
  }

  ul ul li {
    margin-inline-start: var(--sl-sidebar-item-padding-inline);
    border-inline-start: 1px solid var(--sl-color-hairline-light);
    padding-inline-start: var(--sl-sidebar-item-padding-inline);
  }

  .large {
    font-size: var(--sl-text-lg);
    font-weight: 600;
    color: var(--sl-color-gray-2);
  }

  .top-level > li + li {
    margin-top: 0.75rem;
  }

  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.2em var(--sl-sidebar-item-padding-inline);
    line-height: 1.4;
    cursor: pointer;
    user-select: none;
    border-radius: 8px;
    transition: background 0.12s ease, color 0.12s ease;
  }

  summary:hover {
    background: var(--obsrv-active-bg);
    color: var(--obsrv-active-text);
  }

  summary::marker,
  summary::-webkit-details-marker {
    display: none;
  }

  .caret {
    transition: transform 0.2s ease-in-out;
    flex-shrink: 0;
    color: var(--sl-color-gray-3);
  }

  :global([dir='rtl']) .caret {
    transform: rotateZ(180deg);
  }

  [open] > summary .caret {
    transform: rotateZ(90deg);
  }

  a {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    padding: 0.3em var(--sl-sidebar-item-padding-inline);
    line-height: 1.4;
    transition: background 0.12s ease, color 0.12s ease;
  }

  a:hover,
  a:focus {
    background: var(--obsrv-active-bg);
    color: var(--obsrv-active-text);
  }

  [aria-current='page'],
  [aria-current='page']:hover,
  [aria-current='page']:focus {
    font-weight: 600;
    background: var(--obsrv-active-bg) !important;
    border: 1px solid var(--obsrv-active-border);
    color: var(--obsrv-active-text) !important;
    box-shadow: none;
  }

  a > *:not(:last-child),
  .group-label > *:not(:last-child) {
    margin-inline-end: 0.25em;
  }

  [aria-current='page'] .sidebar-group-icon {
    color: currentColor;
    opacity: 0.75;
  }

  /* Group header nav link — sits inside <summary>, no pill background */
  summary a.group-nav-link {
    display: inline;
    padding: 0;
    border-radius: 0;
    background: none !important;
    border: none !important;
    box-shadow: none !important;
    color: inherit;
    font-weight: 600;
  }

  summary a.group-nav-link:hover {
    background: none !important;
    color: var(--obsrv-active-text);
  }

  summary a.group-nav-link[aria-current='page'] {
    color: var(--obsrv-active-text) !important;
    background: none !important;
    border: none !important;
    font-weight: 600;
  }

  /* Icon alignment within group-label */
  .group-label {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .sidebar-group-icon {
    flex-shrink: 0;
    color: currentColor;
    opacity: 0.55;
  }

  @media (min-width: 50rem) {
    .top-level > li + li {
      margin-top: 0.5rem;
    }
    .large {
      font-size: var(--sl-text-base);
    }
    a {
      font-size: var(--sl-text-sm);
    }
    /* Top-level direct links (e.g. Community) get .large but should match
       nested item font size — not the group-header size */
    .top-level > li > a.large {
      font-size: var(--sl-text-sm);
    }
  }
</style>
