---
import { SECTION_ICONS } from '../icons/sections';

const { entry } = Astro.locals.starlightRoute;

// Strip .mdx/.md extension — entry.id may be "index.mdx" or "core-concepts/index.mdx"
const id: string = (entry.id ?? '').replace(/\.mdx?$/, '');
const topSection = id.includes('/') ? id.split('/')[0] : id;
const normalised = (topSection === 'index' || topSection === '') ? '' : topSection;
const isIndex = id === 'index' || id === '' || id.endsWith('/index') || !id.includes('/');
const icon = isIndex ? SECTION_ICONS[normalised] : undefined;
---

{icon ? (
  <div class="page-title-wrap" id="_top">
    <span class="page-title-icon" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="26"
        height="26"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        set:html={icon}
      />
    </span>
    <h1>{entry.data.title}</h1>
  </div>
) : (
  <h1 id="_top">{entry.data.title}</h1>
)}
{entry.data.description && <p class="page-description">{entry.data.description}</p>}

<style>
  h1 {
    margin-top: 1rem;
    font-size: var(--sl-text-h1);
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .page-title-wrap {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .page-title-wrap h1 {
    margin-top: 0;
  }

  .page-title-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* Scale the icon with the H1 so it visually matches the title text */
    font-size: var(--sl-text-h1);
    color: var(--obsrv-active-text);
    flex-shrink: 0;
  }

  .page-title-icon svg {
    width: 0.9em;
    height: 0.9em;
  }

  .page-description {
    margin-top: 0.4rem;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-body-sm);
    line-height: 1.5;
  }
</style>
