---
import { Badge } from '@astrojs/starlight/components';
import { BADGE_ICONS } from '../icons/sections';

interface Props {
  badge: { text: string; variant: string; class?: string };
}

const { badge } = Astro.props;
const key = badge.text.trim().toLowerCase();
const icon = BADGE_ICONS[key];
const isPro = key === 'pro feature';
---

{isPro ? (
  <span class="pro-badge" role="img" title={badge.text} aria-label={badge.text}>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={icon}
    />
    <span>PRO</span>
  </span>
) : icon ? (
  <span class="badge-icon" role="img" title={badge.text} aria-label={badge.text}>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={icon}
    />
  </span>
) : (
  <Badge variant={badge.variant as any} class={badge.class} text={badge.text} />
)}

<style>
  /* Icon-only badge (e.g. "latest" → sparkles). */
  .badge-icon {
    display: inline-flex;
    align-items: center;
    color: var(--obsrv-active-text);
  }
  .badge-icon svg {
    width: 0.95em;
    height: 0.95em;
  }

  /* "Pro feature" → crown + PRO pill, in the brand premium accent. */
  .pro-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.05rem 0.4rem;
    border-radius: 999px;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1.4;
    color: var(--obsrv-orange);
    background: rgba(212, 98, 26, 0.1);
    border: 1px solid rgba(212, 98, 26, 0.3);
  }
  .pro-badge svg {
    width: 0.85em;
    height: 0.85em;
  }

  :global([data-theme='dark']) .pro-badge {
    color: var(--obsrv-orange-light);
    background: rgba(242, 149, 107, 0.12);
    border-color: rgba(242, 149, 107, 0.3);
  }
</style>
