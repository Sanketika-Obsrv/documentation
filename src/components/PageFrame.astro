---
import MobileMenuToggle from 'virtual:starlight/components/MobileMenuToggle';

const { hasSidebar } = Astro.locals.starlightRoute;
---

<div class="page sl-flex">
	<header class="header"><slot name="header" /></header>
	{
		hasSidebar && (
			<nav class="sidebar print:hidden" aria-label={Astro.locals.t('sidebarNav.accessibleLabel')}>
				<MobileMenuToggle />
				<div id="starlight__sidebar" class="sidebar-pane">
					<div class="sidebar-content sl-flex">
						<slot name="sidebar" />
					</div>
				</div>
			</nav>
		)
	}
	<div class="main-frame"><slot /></div>
	<footer class="page-footer print:hidden">
		<a href="https://sanketika.in" target="_blank" rel="noopener" class="page-footer__brand">
			<img src={`${import.meta.env.BASE_URL}/obsrv-footer-logo.png`} alt="Obsrv by Sanketika" class="page-footer__logo" />
		</a>
		<span class="page-footer__copyright">© 2026 Sanketika Consulting Pvt Ltd. All rights reserved.</span>
	</footer>
</div>

<style>
	.page {
		flex-direction: column;
		min-height: 100vh;
	}

	.header {
		z-index: var(--sl-z-index-navbar);
		position: fixed;
		inset-inline-start: 0;
		inset-block-start: 0;
		width: 100%;
		height: var(--sl-nav-height);
		border-bottom: 1px solid var(--sl-color-hairline-shade);
		padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
		padding-inline-end: var(--sl-nav-pad-x);
		background-color: var(--sl-color-bg-nav);
	}

	:global([data-has-sidebar]) .header {
		padding-inline-end: calc(var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size));
	}

	.sidebar-pane {
		visibility: var(--sl-sidebar-visibility, hidden);
		position: fixed;
		z-index: var(--sl-z-index-menu);
		inset-block: var(--sl-nav-height) 0;
		inset-inline-start: 0;
		width: 100%;
		background-color: var(--sl-color-black);
		overflow-y: auto;
		padding-block-end: 3.5rem;
	}

	:global([aria-expanded='true']) ~ .sidebar-pane {
		--sl-sidebar-visibility: visible;
	}

	.sidebar-content {
		height: 100%;
		min-height: max-content;
		padding: 1rem var(--sl-sidebar-pad-x) 0;
		flex-direction: column;
		gap: 1rem;
	}

	@media (min-width: 50rem) {
		.sidebar-content::after {
			content: '';
			padding-bottom: 1px;
		}
	}

	.main-frame {
		/* Grow to fill the viewport so a short page still pushes the footer to the bottom */
		flex: 1 0 auto;
		padding-top: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height));
		padding-inline-start: var(--sl-content-inline-start);
	}

	/* Remove Starlight's built-in footer border (inside .main-frame) to prevent double line */
	:global(.main-frame footer) {
		border-top: none !important;
		border-block-start: none !important;
	}

	.page-footer {
		/* Appear above the fixed sidebars when scrolled to the bottom */
		position: relative;
		z-index: calc(var(--sl-z-index-menu, 9) + 1);
		background: var(--sl-color-bg);
		border-top: 1px solid var(--sl-color-hairline-light);
		padding: 1rem 2rem;
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.page-footer__brand {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		text-decoration: none;
		opacity: 0.85;
		transition: opacity 0.15s ease;
	}

	.page-footer__brand:hover {
		opacity: 1;
	}

	.page-footer__logo {
		height: 28px;
		width: auto;
		display: block;
	}

	:global([data-theme='dark']) .page-footer__logo {
		filter: brightness(0) invert(1);
		opacity: 0.85;
	}

	.page-footer__copyright {
		flex: 1;
		text-align: center;
		font-size: 0.75rem;
		color: var(--sl-color-gray-3);
	}

	@media (min-width: 50rem) {
		:global([data-has-sidebar]) .header {
			padding-inline-end: var(--sl-nav-pad-x);
		}
		.sidebar-pane {
			--sl-sidebar-visibility: visible;
			width: var(--sl-sidebar-width);
			background-color: var(--sl-color-bg-sidebar);
			border-inline-end: 1px solid var(--sl-color-hairline-shade);
		}
	}
</style>
