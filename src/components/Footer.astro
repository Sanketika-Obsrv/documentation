---
// Footer with Obsrv logo (Sanketika branding)
---

<footer class="obsrv-footer">
  <a href="https://sanketika.in" target="_blank" rel="noopener" class="obsrv-footer__brand">
    <img
      src={`${import.meta.env.BASE_URL}obsrv-footer-logo.png`}
      alt="Obsrv by Sanketika"
      class="obsrv-footer__logo"
    />
  </a>
  <span class="obsrv-footer__copyright">© 2026 Sanketika Consulting Pvt Ltd</span>
</footer>

<style>
  .obsrv-footer {
    border-top: 1px solid var(--sl-color-hairline-light);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.5rem;
    background: transparent;
  }

  .obsrv-footer__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }

  .obsrv-footer__brand:hover {
    opacity: 1;
  }

  .obsrv-footer__logo {
    height: 28px;
    width: auto;
    object-fit: contain;
  }

  /* Invert logo in dark mode so it stays visible */
  [data-theme='dark'] .obsrv-footer__logo {
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }

  .obsrv-footer__copyright {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
  }
</style>
