---
import type { Props } from '@astrojs/starlight/props';
---

<a href={import.meta.env.BASE_URL} class="site-title" aria-label="Obsrv">
  <img src={`${import.meta.env.BASE_URL}obsrv-logo.png`} alt="Obsrv" class="site-logo" />
</a>

<style>
  .site-title {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .site-logo {
    height: 36px;
    width: auto;
    object-fit: contain;
  }
  .site-title:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
