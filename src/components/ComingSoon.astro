---
/**
 * Friendly placeholder for pages whose content is still being written.
 * Replaces bare "<to be updated>" / "Coming soon" text with a polished panel:
 * a gradient icon badge, a heading, a message (default slot), and a status pill.
 *
 * Usage:
 *   <ComingSoon icon="database" eta="Targeted for the next release">
 *     This example dataset walkthrough is on its way.
 *   </ComingSoon>
 */
type IconKey = 'pencil' | 'database' | 'file' | 'rocket' | 'clock';

interface Props {
  title?: string;
  icon?: IconKey;
  /** Status pill text. Pass an empty string to hide the pill. */
  eta?: string;
}

const { title = 'Coming soon', icon = 'pencil', eta = 'Planned for an upcoming release' } =
  Astro.props;

// lucide.dev icon paths (24×24 stroke)
const ICONS: Record<IconKey, string> = {
  pencil: `<path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/><path d="m15 5 3 3"/>`,
  database: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>`,
  file: `<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/>`,
  rocket: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>`,
  clock: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
};
---

<div class="coming-soon">
  <span class="coming-soon__badge">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="34"
      height="34"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={ICONS[icon]}
    />
  </span>

  <h2 class="coming-soon__title">{title}</h2>

  <p class="coming-soon__body">
    <slot>This page is being written and will be updated soon.</slot>
  </p>

  {eta && (
    <span class="coming-soon__pill">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      {eta}
    </span>
  )}
</div>

<style>
  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.85rem;
    margin: 2rem auto;
    max-width: 32rem;
    padding: 2.75rem 2rem;
    border: 1px solid var(--obsrv-sidebar-border);
    border-radius: 16px;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(79, 134, 200, 0.08), transparent 70%),
      var(--obsrv-sidebar-card-bg, rgba(255, 255, 255, 0.6));
  }

  .coming-soon__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 16px;
    color: #fff;
    background: linear-gradient(135deg, var(--obsrv-orange), #f59e0b);
    box-shadow: 0 8px 22px rgba(212, 98, 26, 0.28);
  }

  .coming-soon__title {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--sl-color-white);
    /* Override the global h2 divider styling from custom.css */
    border-bottom: none;
    padding: 0;
  }

  .coming-soon__body {
    margin: 0;
    max-width: 28rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
  }

  .coming-soon__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.35rem;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--obsrv-orange);
    background: var(--obsrv-pro-bg, rgba(212, 98, 26, 0.08));
    border: 1px solid var(--obsrv-pro-border, rgba(212, 98, 26, 0.3));
  }

  :global([data-theme='dark']) .coming-soon__pill {
    color: var(--obsrv-orange-light);
    background: rgba(242, 149, 107, 0.12);
    border-color: rgba(242, 149, 107, 0.3);
  }

  /* Optional extra content (e.g. a list of upcoming items) sits below the panel */
  .coming-soon + :global(*) {
    margin-top: 1.5rem;
  }
</style>
