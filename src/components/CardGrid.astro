---
// Icon set — all paths are from lucide.dev (ISC licensed), 24×24 stroke.
type IconKey =
  | 'book' | 'layers' | 'chart' | 'server' | 'code' | 'terminal' | 'puzzle'
  | 'rocket' | 'database' | 'api' | 'eye' | 'sparkles' | 'plug' | 'cpu'
  | 'activity' | 'map' | 'calendar' | 'leaf' | 'graduation' | 'radio'
  | 'network' | 'shield' | 'gauge' | 'monitor' | 'archive' | 'trending'
  | 'wrench' | 'bell' | 'migrate' | 'boxes' | 'checklist' | 'warehouse'
  | 'drive' | 'search' | 'file' | 'download' | 'send' | 'tag';

interface Card {
  title: string;
  description: string;
  href: string;
  gradient?: string;   // CSS gradient string (optional — auto-assigned if omitted)
  icon?: IconKey;      // icon key for the SVG
  image?: string;      // fallback: photo URL
}

interface Props {
  cards: Card[];
}

const { cards } = Astro.props;

// Prepend the site base (e.g. "/documentation") to internal links and ensure a
// trailing slash so directory-style pages resolve on static hosts (GitHub Pages).
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
function withBase(href: string): string {
  if (!href.startsWith('/')) return href; // external / anchor — leave as-is
  return `${base}${href.replace(/\/$/, '')}/`;
}

// Vibrant gradient palette — cycled by card index when a card doesn't set its
// own `gradient`, so index pages get colourful, varied card headers for free.
const GRADIENTS = [
  'linear-gradient(135deg, #8b5cf6, #3b82f6)',
  'linear-gradient(135deg, #10b981, #0ea5e9)',
  'linear-gradient(135deg, #f59e0b, #ef4444)',
  'linear-gradient(135deg, #6366f1, #06b6d4)',
  'linear-gradient(135deg, #f97316, #ec4899)',
  'linear-gradient(135deg, #14b8a6, #22c55e)',
  'linear-gradient(135deg, #0ea5e9, #6366f1)',
  'linear-gradient(135deg, #f43f5e, #8b5cf6)',
];

// SVG icon paths (24×24 stroke, rendered at 40px) — lucide.dev
