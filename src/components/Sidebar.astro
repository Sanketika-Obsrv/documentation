---
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarSublist from './SidebarSublist.astro';

const { sidebar } = Astro.locals.starlightRoute;
---

{/* No SidebarPersister: each page resets to "active section only" — other
    sections render collapsed by default but can be expanded manually. */}
<SidebarSublist sublist={sidebar} />

<div class="md:sl-hidden">
  <MobileMenuFooter />
</div>

<script>
  // API operation pages are plugin-injected routes that aren't in the sidebar,
  // so Starlight can't mark their parent section active. PageTitle renders a
  // "back to section" link on those pages; mirror its target onto the matching
  // sidebar Section link so the section stays highlighted while reading an endpoint.
  function highlightApiSection() {
    const back = document.querySelector<HTMLAnchorElement>('a[data-api-section-back]');
    if (!back) return;
    const target = new URL(back.href).pathname.replace(/\/+$/, '');
    document
      .querySelectorAll<HTMLAnchorElement>('.sidebar-content a[href]')
      .forEach((a) => {
        if (new URL(a.href).pathname.replace(/\/+$/, '') === target) {
          a.setAttribute('aria-current', 'page');
          const details = a.closest('details');
          // Open and highlight the parent "API Specification" section so the
          // active section shows even though endpoints aren't sidebar entries.
          details?.setAttribute('open', '');
          details?.classList.add('active-section');
        }
      });
  }
  highlightApiSection();
  document.addEventListener('astro:page-load', highlightApiSection);
</script>
