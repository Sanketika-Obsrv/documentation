---
/**
 * Embeds an interactive API reference (Swagger UI) for an OpenAPI spec.
 * The spec is fetched client-side, so nothing is bundled at build time.
 *
 * Usage: <ApiReference url="https://.../openapi.yml" />
 */
interface Props {
  url: string;
}
const { url } = Astro.props;
---

<link rel="stylesheet" href="https://unpkg.com/swagger-ui-dist@5/swagger-ui.css" />
<div id="swagger-ui" class="api-reference"></div>

<script define:vars={{ specUrl: url }}>
  (function () {
    function render() {
      window.SwaggerUIBundle({
        url: specUrl,
        dom_id: '#swagger-ui',
        deepLinking: true,
        docExpansion: 'list',
        defaultModelsExpandDepth: 0,
      });
    }
    if (window.SwaggerUIBundle) {
      render();
      return;
    }
    var s = document.createElement('script');
    s.src = 'https://unpkg.com/swagger-ui-dist@5/swagger-ui-bundle.js';
    s.crossOrigin = 'anonymous';
    s.onload = render;
    document.head.appendChild(s);
  })();
</script>

<style>
  .api-reference {
    margin-top: 1rem;
  }
  :global(.swagger-ui) {
    font-family: var(--sl-font);
  }
  :global(.swagger-ui .information-container) {
    padding: 1rem 0;
  }
</style>
